---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

const posts = (await getCollection("blog")).sort(
  (a, b) => Number(b.data.year ?? 0) - Number(a.data.year ?? 0),
);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead
      title={SITE_TITLE + SITE_DESCRIPTION}
      description={SITE_DESCRIPTION}
    />
    <style>
      main {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 2rem;
        box-sizing: border-box;
        overflow-x: hidden; /* Parche de seguridad para evitar scroll horizontal */
      }
      ul {
        display: flex;
        flex-direction: column;
        gap: 8rem;
        list-style-type: none;
        margin: 0;
        padding: 0 !important; /* Forzamos a eliminar el padding fantasma del navegador */
        width: 100%;
      }
      li.project-card {
        display: flex;
        align-items: center;
        gap: 5rem;
        width: 100%;
        box-sizing: border-box;
      }

      li.project-card:nth-child(even) {
        flex-direction: row-reverse;
      }

      .project-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 300px;
      }
      .project-image {
        flex: 1.2;
        width: 100%;
      }
      .project-image img {
        width: 100%;
        height: auto;
        border-radius: 24px;
        object-fit: cover;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        transition:
          transform 0.4s ease,
          box-shadow 0.4s ease;
      }
      .project-image a:hover img {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.12);
      }

      /* Tipografía de la tarjeta */
      .project-number {
        color: #d97a66;
        font-size: 0.8rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 0.75rem;
      }
      .title {
        font-family: "Georgia", serif;
        font-size: 3.2rem;
        margin: 0 0 0.75rem 0;
        color: #1a1a1a;
        line-height: 1.1;
      }
      .location {
        color: #666;
        font-size: 0.95rem;
        margin-bottom: 2.5rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }

      /* Grilla de detalles */
      .details-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        padding: 1.5rem 0;
        border-top: 1px solid #eaeaea;
        border-bottom: 1px solid #eaeaea;
        margin-bottom: 1.5rem;
      }
      .detail-item {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
      }
      .detail-label {
        font-size: 0.7rem;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }
      .detail-value {
        font-size: 1.05rem;
        color: #1a1a1a;
        font-weight: 500;
      }

      .link-details {
        color: #d97a66;
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        transition: opacity 0.2s;
      }
      .link-details:hover {
        opacity: 0.7;
      }

      /* =========================================
         MEDIA QUERIES
         ========================================= */

      @media (max-width: 992px) {
        main {
          padding: 3rem 2rem;
        }
        ul {
          gap: 5rem;
        }
        li.project-card {
          gap: 3rem;
        }
        .title {
          font-size: 2.6rem;
        }
      }

      @media (max-width: 768px) {
        main {
          padding: 2rem 1.25rem;
        }
        ul {
          gap: 4rem;
        }

        /* Solución principal para el problema del gap */
        li.project-card,
        li.project-card:nth-child(even) {
          flex-direction: column-reverse;
          align-items: flex-start; /* ESTO evita que el contenido se centre y empuje la imagen */
          gap: 1.5rem;
        }

        .project-content {
          min-width: 100%; /* Forzamos a que el texto ocupe todo el ancho disponible */
        }

        .project-image img {
          border-radius: 16px; /* Recuperamos los bordes en móvil */
        }

        .title {
          font-size: 2.2rem;
          margin-bottom: 0.5rem;
        }

        .location {
          margin-bottom: 1.5rem;
        }

        .details-grid {
          grid-template-columns: 1fr 1fr;
          gap: 1rem;
          padding: 1.25rem 0;
        }

        .detail-value {
          font-size: 0.95rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section>
        <ul>
          {
            posts.map((post, index) => (
              <li class="project-card">
                <div class="project-content">
                  <span class="project-number">
                    Proyecto {String(index + 1).padStart(2, "0")}
                  </span>

                  <h2 class="title">{post.data.title}</h2>

                  {post.data.location && (
                    <div class="location">
                      <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                        <circle cx="12" cy="10" r="3" />
                      </svg>
                      {post.data.location}
                    </div>
                  )}

                  <div class="details-grid">
                    <div class="detail-item">
                      <span class="detail-label">Arquitecto</span>
                      <span class="detail-value">
                        {post.data.artist || "No especificado"}
                      </span>
                    </div>
                    <div class="detail-item">
                      <span class="detail-label">Año</span>
                      <span class="detail-value">{post.data.year}</span>
                    </div>
                    <div class="detail-item">
                      <span class="detail-label">Superficie</span>
                      <span class="detail-value">
                        {post.data.surface || "-"}
                      </span>
                    </div>
                    <div class="detail-item">
                      <span class="detail-label">Tipología</span>
                      <span class="detail-value">{post.data.tipo || "-"}</span>
                    </div>
                  </div>

                  <a href={`/blog/${post.id}/`} class="link-details">
                    Ver detalles ↗
                  </a>
                </div>

                <div class="project-image">
                  <a href={`/blog/${post.id}/`}>
                    {post.data.heroImage && (
                      <Image
                        width={800}
                        height={600}
                        src={post.data.heroImage}
                        alt={post.data.title}
                      />
                    )}
                  </a>
                </div>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
