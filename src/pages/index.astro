---
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import HeroImage from "../assets/index.jpeg";
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead
      title={SITE_TITLE + SITE_DESCRIPTION}
      description={SITE_DESCRIPTION}
    />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <Image
          src={HeroImage}
          alt="Fondo de proyectos de arquitectura"
          class="hero-bg"
        />

        <div class="hero-overlay"></div>

        <div class="hero-content">
          <span class="kicker">PANTONE • ESTUDIO DE ARQUITECTURA</span>
          <h1>Espacios que enmarcan<br />el paisaje</h1>
          <p>
            Una colección de proyectos de arquitectura moderna. Desplázate para
            recorrer cada edificio, su arquitecto y sus detalles.
          </p>
          <a href="/blog" class="btn">Ver proyectos</a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  /* Reset básico para asegurar que no haya márgenes indeseados */
  main {
    width: 100%;
    margin: 0;
    padding: 0;
  }

  /* Contenedor principal del Hero */
  .hero {
    position: relative;
    width: 100%;
    height: 85vh; /* Un poco más inmersivo en escritorio */
    min-height: 600px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Imagen de fondo ocupando todo el espacio */
  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  /* Filtro con degradado: Más oscuro a la izquierda (donde va el texto), transparente a la derecha */
  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.75) 0%,
      rgba(0, 0, 0, 0.2) 100%
    );
    z-index: 2;
  }

  /* Contenedor del texto */
  .hero-content {
    position: relative;
    z-index: 3;
    max-width: 800px;
    padding: 0 5%; /* Usamos porcentaje para fluidez responsiva */
    color: white;
  }

  /* Estilos tipográficos */
  .kicker {
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 1.2rem;
    display: block;
    color: #fbd3c6; /* Un tono sutil basado en el color terracota */
    font-weight: 600;
  }

  h1 {
    font-family: "Georgia", serif; /* Heredamos la fuente de los proyectos */
    font-size: clamp(
      2.5rem,
      6vw,
      4.8rem
    ); /* Escala perfecta en cualquier pantalla */
    color: white;
    line-height: 1.05;
    margin: 0 0 1.5rem 0;
    font-weight: normal; /* Georgia luce más elegante sin bold extremo */
  }

  p {
    font-size: 1.15rem;
    line-height: 1.6;
    margin-bottom: 2.5rem;
    max-width: 550px;
    color: rgba(255, 255, 255, 0.9);
  }

  /* Botón con micro-interacciones */
  .btn {
    display: inline-block;
    background-color: #d67a53;
    color: white;
    padding: 14px 32px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 500;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
  }

  .btn:hover {
    background-color: #bc6541;
    transform: translateY(-2px); /* Se eleva un poco al pasar el mouse */
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
  }

  /* =========================================
     MEDIA QUERIES (MÓVILES Y TABLETS)
     ========================================= */

  @media (max-width: 768px) {
    .hero {
      height: 100vh; /* En celular, que el hero ocupe toda la pantalla inicial */
      justify-content: center; /* Centramos vertical y horizontalmente */
      text-align: center;
    }

    .hero-overlay {
      /* En móvil el texto está centrado, así que el filtro debe ser uniforme */
      background: rgba(0, 0, 0, 0.55);
    }

    .hero-content {
      display: flex;
      flex-direction: column;
      align-items: center; /* Asegura que el botón y textos se centren */
      padding: 0 1.5rem;
    }

    .kicker {
      font-size: 0.75rem;
      margin-bottom: 1rem;
    }

    h1 {
      /* Ajustamos el salto de línea para móviles */
      font-size: clamp(2.2rem, 10vw, 3rem);
      margin-bottom: 1rem;
    }

    p {
      font-size: 1rem;
      margin-bottom: 2rem;
    }
  }
</style>
